# Корневой .env для docker compose — staging на VDS.
# Скопируйте: cp deploy/env/staging.compose.env.example .env
#
# COMPOSE_PROJECT_NAME отличается от prod — это полностью изолирует контейнеры,
# сети и volume'ы. Можно держать staging и prod рядом на одном сервере.

COMPOSE_PROJECT_NAME=guard-staging

# Порты на хост не публикуются — трафик принимает reverse-proxy (deploy/proxy).
# Если временно понадобится прямой доступ — раскомментируйте в docker-compose.staging.yml.

# PostgreSQL (должно совпадать с backend/.env)
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
