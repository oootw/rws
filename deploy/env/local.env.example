APP_NAME="Guard Reviews"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_DOMAIN=localhost
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU
APP_TIMEZONE=Europe/Moscow

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Docker-сервисы (docker-compose.base.yml)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=change-me

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@otziv.space"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_ALERT_EMAIL=

SUBSCRIPTION_BASE_PRICE=99000
SUBSCRIPTION_EXTRA_PLACE_PRICE=29000
SUBSCRIPTION_DURATION_DAYS=30
SUBSCRIPTION_REMINDER_DAYS=3

DATA_RETENTION_DAYS=365

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_API_URL=https://api.telegram.org

MAX_BOT_ENABLED=false

FOUNDER_TELEGRAM_USERNAME=

TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2

YANDEX_CAPTCHA_CLIENT_KEY=
YANDEX_CAPTCHA_SERVER_KEY=

# Локально: ?tenant=demo на scan-форме (см. docs/DOCKER.md)
VITE_ALLOW_TENANT_QUERY=1
