APP_NAME="Guard Reviews"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://otziv.space
APP_DOMAIN=otziv.space

# Если на одном VDS живёт и staging, и prod — перечислите оба apex'а
# (этот эндпоинт спрашивает Caddy перед выпуском TLS-сертификата).
TLS_ALLOWED_DOMAINS="otziv.space,staging.otziv.space"
APP_LOCALE=ru
APP_TIMEZONE=Europe/Moscow

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@otziv.space"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_ALERT_EMAIL=

SUBSCRIPTION_BASE_PRICE=99000
SUBSCRIPTION_EXTRA_PLACE_PRICE=29000
SUBSCRIPTION_DURATION_DAYS=30
SUBSCRIPTION_REMINDER_DAYS=3

DATA_RETENTION_DAYS=365

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Из РФ VDS api.telegram.org заблокирован. Поднимите свой relay (см.
# deploy/telegram-proxy/ и docs/TELEGRAM_RU.md) и пропишите его сюда:
#   TELEGRAM_API_URL=https://tg.example.com
#   TELEGRAM_PROXY_SECRET=<тот же секрет, что в proxy/.env>
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_PROXY_SECRET=

# Несколько прокси с автоматическим failover'ом (порядок = приоритет).
# Если задан — TELEGRAM_API_URL игнорируется. При сбое одного URL клиент
# на лету переходит к следующему; в логах warning о фолбэке.
# TELEGRAM_API_URLS="https://tg-primary.example.com,https://tg-backup.example.com"

MAX_BOT_ENABLED=false

FOUNDER_TELEGRAM_USERNAME=

TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2

YANDEX_CAPTCHA_CLIENT_KEY=
YANDEX_CAPTCHA_SERVER_KEY=
