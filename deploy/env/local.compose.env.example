# Корневой .env для docker compose — локальная разработка.
# Скопируйте: cp deploy/env/local.compose.env.example .env

COMPOSE_PROJECT_NAME=guard-local

# Порт nginx на хосте (откроется http://localhost:${HTTP_PORT})
HTTP_PORT=8080

# Порты для `docker compose up` (только Postgres + Redis на хост)
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL (должно совпадать с backend/.env)
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=change-me

# Локальная сборка фронта: разрешить ?tenant=demo на /s/
VITE_ALLOW_TENANT_QUERY=1
