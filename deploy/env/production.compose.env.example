# Корневой .env для docker compose — production на VDS.
# Скопируйте: cp deploy/env/production.compose.env.example .env
#
# COMPOSE_PROJECT_NAME отличается от staging — это полностью изолирует
# контейнеры, сети и volume'ы.

COMPOSE_PROJECT_NAME=guard-prod

# PostgreSQL (должно совпадать с backend/.env)
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
