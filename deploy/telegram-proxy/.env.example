# Доменное имя relay'я (нужна A-запись на IP этого VPS).
PROXY_DOMAIN=tg.example.com

# E-mail для Let's Encrypt.
ACME_EMAIL=admin@example.com

# Произвольная длинная строка-секрет (32+ символов).
# Будет проверяться в заголовке X-Proxy-Secret — relay отбросит все
# запросы без него. Это защищает ваш канал от чужих ботов, которые
# случайно/специально найдут публичный домен.
#
# Сгенерируйте: openssl rand -hex 32
TG_PROXY_SHARED_SECRET=CHANGE_ME_long_random_string
