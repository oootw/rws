{
  "name": "guard-reviews-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace scan",
    "dev:owner": "npm run dev --workspace owner",
    "build": "npm run build --workspace scan && npm run build --workspace owner",
    "build:scan": "npm run build --workspace scan",
    "build:owner": "npm run build --workspace owner",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "scan",
    "owner",
    "shared"
  ]
}
