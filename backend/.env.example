# Шаблон Laravel .env. Для развёртывания удобнее использовать готовые
# профили в deploy/env/ через scripts/init-env.sh:
#
#   bash scripts/init-env.sh local
#   bash scripts/init-env.sh staging
#   bash scripts/init-env.sh production

APP_NAME="Guard Reviews"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_DOMAIN=localhost
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU
APP_TIMEZONE=Europe/Moscow

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker-сервисы (см. docker-compose.base.yml)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=change-me

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@otziv.space"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_ALERT_EMAIL=

# Цены подписки в копейках
SUBSCRIPTION_BASE_PRICE=99000
SUBSCRIPTION_EXTRA_PLACE_PRICE=29000
SUBSCRIPTION_DURATION_DAYS=30
SUBSCRIPTION_REMINDER_DAYS=3

DATA_RETENTION_DAYS=365

# Telegram (в РФ исходящий API часто требует KZ-прокси)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=

# MAX Messenger — фаза 2+
MAX_BOT_ENABLED=false
MAX_BOT_TOKEN=
MAX_BOT_WEBHOOK_SECRET=

FOUNDER_TELEGRAM_USERNAME=

# Tinkoff Acquiring
TINKOFF_TERMINAL_KEY=
TINKOFF_SECRET_KEY=
TINKOFF_API_URL=https://securepay.tinkoff.ru/v2
# Опционально — иначе строятся от APP_URL:
# TINKOFF_NOTIFICATION_URL=https://otziv.space/api/webhooks/tinkoff
# TINKOFF_SUCCESS_URL=https://otziv.space/payment/success
# TINKOFF_FAIL_URL=https://otziv.space/payment/fail

# Yandex SmartCaptcha
YANDEX_CAPTCHA_CLIENT_KEY=
YANDEX_CAPTCHA_SERVER_KEY=

VITE_APP_NAME="${APP_NAME}"
