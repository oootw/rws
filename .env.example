# Корневой .env для docker compose.
#
# Не редактируйте напрямую — используйте готовые профили в deploy/env/
# через scripts/init-env.sh:
#
#   bash scripts/init-env.sh local        → deploy/env/local.compose.env.example
#   bash scripts/init-env.sh staging      → deploy/env/staging.compose.env.example
#   bash scripts/init-env.sh production   → deploy/env/production.compose.env.example
#
# Этот файл сохранён как дефолт для совместимости. Значения дублируют
# deploy/env/local.compose.env.example.

COMPOSE_PROJECT_NAME=guard-local
HTTP_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379

DB_DATABASE=guard_reviews
DB_USERNAME=guard
DB_PASSWORD=change-me

VITE_ALLOW_TENANT_QUERY=1
